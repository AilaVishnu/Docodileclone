{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@stomp/stompjs": "^7.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.16.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.1",
    "sockjs-client": "^1.6.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "prestart": "node -e \"try { require('child_process').execSync('npx --yes kill-port 3000', { stdio: 'inherit' }); } catch (e) {}\"",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.stories.tsx",
          "src/sb/**"
        ],
        "rules": {
          "react-hooks/rules-of-hooks": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-onboarding": "^10.4.4",
    "@storybook/preset-create-react-app": "^10.4.4",
    "@storybook/react-webpack5": "^10.4.4",
    "@types/sockjs-client": "^1.5.4",
    "eslint-plugin-storybook": "^10.4.4",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "prop-types": "^15.8.1",
    "storybook": "^10.4.4",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}