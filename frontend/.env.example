# Backend API base URL. Set this in .env.local for local development
# and in your CI/CD environment for production builds.
# Example: https://api.yourdomain.com
REACT_APP_API_URL=http://localhost:8080

# Tenant (clinic) for local dev ONLY on plain localhost (which has no subdomain).
# Sent as the X-Tenant header so the schema-per-clinic backend knows the clinic.
# Ignored when the app runs on a real subdomain (e.g. tskin.lvh.me / tskin.docodile.app),
# where the subdomain wins. Match a provisioned clinic schema (e.g. tskin).
REACT_APP_DEV_TENANT=tskin
